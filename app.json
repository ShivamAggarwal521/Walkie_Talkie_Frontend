{
  "expo": {
    "name": "Walkie Talkie",
    "slug": "walkie-talkie-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1c1c1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to send voice messages."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO"
      ],
      "package": "com.shivam521.walkietalkieapp"
    },
    "extra": {
      "eas": {
        "projectId": "5e429b00-3951-4f28-bcdb-8179c0a5d35b"
      }
    },
    "owner": "shivam521"
  }
}
